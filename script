--//---------------------------------------------------------------
--// Animation speed boost
--//---------------------------------------------------------------
local function boostAnims()
    local char = plr.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then return end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        local n = track.Name:lower()
        if n:find("punch") or n:find("kick") or n:find("slam") or n:find("head") or n:find("round") or n:find("grab") then
            if track.Speed ~= State.SwingMult then
                track:AdjustSpeed(State.SwingMult)
            end
        end
    end
end

local function resetAnims()
    pcall(function()
        local animator = plr.Character:FindFirstChildOfClass("Humanoid"):FindFirstChildOfClass("Animator")
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            track:AdjustSpeed(1)
        end
    end)
end

--//---------------------------------------------------------------
--// Hitbox expand (only Fist parts, stays invisible)
--//---------------------------------------------------------------
local origFistSize
local function setHitbox(on)
    local char = plr.Character
    if not char then return end
    if on then
        for _, name in ipairs({"RightHand", "LeftHand"}) do
            local p = char:FindFirstChild(name)
            if not p then continue end
            local fist = p:FindFirstChild("Fist")
            if not fist then continue end
            if not origFistSize then origFistSize = fist.Size end
            fist.Size = Vector3.new(State.HitboxSize, State.HitboxSize, State.HitboxSize)
            fist.Transparency = 1
            fist.CanCollide = false
        end
    else
        for _, name in ipairs({"RightHand", "LeftHand"}) do
            local p = char:FindFirstChild(name)
            if not p then continue end
            local fist = p:FindFirstChild("Fist")
            if fist and origFistSize then
                fist.Size = origFistSize
                fist.Transparency = 1
            end
        end
    end
end

--//---------------------------------------------------------------
--// Reach (setconstant on hit function)
--//---------------------------------------------------------------
local function setReach(val)
    if hitFunc then
        pcall(setconstant, hitFunc, 1, val)
    end
end

--//---------------------------------------------------------------
--// ESP (parent to CoreGui so game can't remove them)
--//---------------------------------------------------------------
local espObjects = {}

local function clearESP()
    for _, h in pairs(espObjects) do
        pcall(function() h:Destroy() end)
    end
    table.clear(espObjects)
end

local function updateESP()
    if not State.ESP and not State.Highlight then
        clearESP()
        return
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if not espObjects[p] or not espObjects[p].Parent then
                if espObjects[p] then pcall(function() espObjects[p]:Destroy() end) end
                local h = Instance.new("Highlight")
                h.FillColor = Color3.fromRGB(255, 50, 50)
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
                h.FillTransparency = State.Highlight and 0.5 or 1
                h.OutlineTransparency = State.ESP and 0 or 1
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                h.Adornee = p.Character
                h.Parent = CoreGui
                espObjects[p] = h
            else
                local h = espObjects[p]
                h.Adornee = p.Character
                h.FillTransparency = State.Highlight and 0.5 or 1
                h.OutlineTransparency = State.ESP and 0 or 1
            end
        end
    end
    for p, h in pairs(espObjects) do
        if not p or not p.Parent or not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function() h:Destroy() end)
            espObjects[p] = nil
        end
    end
end

--//---------------------------------------------------------------
--// Kill aura (firetouchinterest on nearby enemies)
--//---------------------------------------------------------------
local lastAura = 0
local AURA_CD = 0.15

local function killAura()
    local now = tick()
    if now - lastAura < AURA_CD then return end
    lastAura = now
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local rh = char:FindFirstChild("RightHand")
    local fist = rh and rh:FindFirstChild("Fist")
    if not fist then
        local lh = char:FindFirstChild("LeftHand")
        fist = lh and lh:FindFirstChild("Fist")
    end
    if not fist then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr and p.Character then
            local eHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local eHum = p.Character:FindFirstChild("Humanoid")
            if eHRP and eHum and eHum.Health > 0 then
                local dist = (hrp.Position - eHRP.Position).Magnitude
                if dist <= State.KillAuraRange then
                    pcall(firetouchinterest, fist, eHRP, 0)
                    task.defer(pcall, firetouchinterest, fist, eHRP, 1)
                end
            end
        end
    end
end

--//---------------------------------------------------------------
--// Main heartbeat loop
--//---------------------------------------------------------------
local lastRefresh = 0
local REFRESH_CD = 2

local function refreshRefs()
    local now = tick()
    if now - lastRefresh < REFRESH_CD then return end
    lastRefresh = now
    combatFunc = findCombatFunc()
    slamInput, slamRender = findSlamFuncs()
    hitFunc = findHitFunc()
    findStaminaFuncs()
end

local function trySetup(fn, idx, val)
    local ok = pcall(setupvalue, fn, idx, val)
    return ok
end

cons.main = RunService.Heartbeat:Connect(function()
    --// Swing speed
    if State.SwingSpeed then
        boostAnims()
        if combatFunc then
            local ok = pcall(function()
                setupvalue(combatFunc, 18, 0)
                setupvalue(combatFunc, 2, false)
                setupvalue(combatFunc, 3, false)
                setupvalue(combatFunc, 4, false)
                setupvalue(combatFunc, 5, false)
                setupvalue(combatFunc, 8, false)
            end)
            if not ok then combatFunc = nil; refreshRefs() end
        else
            refreshRefs()
        end
    end

    --// Inf slam
    if State.InfSlam then
        if slamInput then
            if not trySetup(slamInput, 17, 100) then slamInput = nil; refreshRefs() end
        else
            refreshRefs()
        end
        if slamRender then
            if not trySetup(slamRender, 8, 100) then slamRender = nil; refreshRefs() end
        else
            refreshRefs()
        end
        pcall(function()
            plr.PlayerGui.UI.Bars.Slam.Bar.Size = UDim2.new(1, 0, 1, 0)
        end)
    end

    --// Inf stamina
    if State.InfStamina then
        if staminaBar then
            local ok = pcall(setupvalue, staminaBar, 3, 100)
            if ok then pcall(setupvalue, staminaBar, 5, true) end
            if not ok then staminaBar = nil; refreshRefs() end
        else
            refreshRefs()
        end
        if staminaDrain then
            local ok = pcall(setupvalue, staminaDrain, 1, 100)
            if ok then pcall(setupvalue, staminaDrain, 2, true) end
            if not ok then staminaDrain = nil; refreshRefs() end
        else
            refreshRefs()
        end
    end

    --// Kill aura (reset debounces so hits register + fire touches)
    if State.KillAura then
        if combatFunc then
            pcall(function()
                setupvalue(combatFunc, 18, 0)
                setupvalue(combatFunc, 2, false)
                setupvalue(combatFunc, 3, false)
                setupvalue(combatFunc, 4, false)
                setupvalue(combatFunc, 5, false)
                setupvalue(combatFunc, 8, false)
            end)
        else
            refreshRefs()
        end
        killAura()
    end

    --// Walk speed
    if State.WalkSpeed then
        pcall(function() plr.Character.Humanoid.WalkSpeed = State.WalkSpeedVal end)
    end

    --// ESP
    updateESP()
end)

--//---------------------------------------------------------------
--// Respawn handler
--//---------------------------------------------------------------
cons.respawn = plr.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid")
    origFistSize = nil
    task.wait(1)
    for i = 1, 10 do
        combatFunc = findCombatFunc()
        slamInput, slamRender = findSlamFuncs()
        hitFunc = findHitFunc()
        findStaminaFuncs()
        if combatFunc and slamInput and staminaBar then break end
        task.wait(0.5)
    end
    lastRefresh = tick()
    if State.Reach then setReach(State.ReachVal) end
    if State.HitboxExpand then setHitbox(true) end
end)

--// Player removing for ESP cleanup
cons.playerRemoving = Players.PlayerRemoving:Connect(function(p)
    if espObjects[p] then
        pcall(function() espObjects[p]:Destroy() end)
        espObjects[p] = nil
    end
end)

