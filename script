--// Toggle buttons
local toggles = {}
local function makeToggle(name, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 15
    btn.LayoutOrder = order
    btn.AutoButtonColor = false
    btn.Parent = MainFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    toggles[name] = false
    local function refresh()
        btn.Text = name .. (toggles[name] and ": ON" or ": OFF")
        btn.TextColor3 = toggles[name] and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
    end
    refresh()
    btn.MouseButton1Click:Connect(function()
        toggles[name] = not toggles[name]
        refresh()
    end)
end
makeToggle("Kill Aura", 1)
makeToggle("Health ESP", 2)
makeToggle("Inf Stamina", 3)
