--//---------------------------------------------------------------
--// Combat func finders (setupvalue only, no hooks)
--//---------------------------------------------------------------
local function safeGetGC()
    local ok, gc = pcall(getgc, false)
    if ok and gc then return gc end
    ok, gc = pcall(getgc)
    if ok and gc then return gc end
    return {}
end

local function findCombatFunc()
    for _, v in ipairs(safeGetGC()) do
        if type(v) == "function" then
            local ok, c = pcall(getconstants, v)
            if ok and c then
                local a, b, d = false, false, false
                for _, k in ipairs(c) do
                    if k == "tick" then a = true
                    elseif k == "punch" then b = true
                    elseif k == "delay" then d = true end
                end
                if a and b and d then return v end
            end
        end
    end
end

local function findSlamFuncs()
    local inputHandler, slamRender
    for _, v in ipairs(safeGetGC()) do
        if type(v) == "function" then
            local ok, c = pcall(getconstants, v)
            if ok and c then
                local a, b, d, e = false, false, false, false
                for _, k in ipairs(c) do
                    if k == "Slam" then a = true
                    elseif k == "FireServer" then b = true
                    elseif k == "fist" then d = true
                    elseif k == "cycle" then e = true end
                end
                if a and b and d and not inputHandler then inputHandler = v end
                if a and b and e and not slamRender then slamRender = v end
            end
        end
    end
    return inputHandler, slamRender
end

local function findHitFunc()
    for _, v in ipairs(safeGetGC()) do
        if type(v) == "function" then
            local ok, c = pcall(getconstants, v)
            if ok and c then
                local a, b, d = false, false, false
                for _, k in ipairs(c) do
                    if k == "Touched" then a = true
                    elseif k == "combat" then b = true
                    elseif k == "Length" then d = true end
                end
                if a and b and d then return v end
            end
        end
    end
end

--// Stamina func finders
local staminaBar, staminaDrain

local function scanStaminaFrom(gcList)
    for _, v in ipairs(gcList) do
        if type(v) == "function" then
            local ok, ups = pcall(getupvalues, v)
            if ok and ups then
                if not staminaBar
                    and typeof(ups[1]) == "Instance" and ups[1].ClassName == "TweenService"
                    and type(ups[3]) == "number" and type(ups[4]) == "number"
                    and type(ups[5]) == "boolean" and type(ups[6]) == "number" and ups[6] < 1 then
                    staminaBar = v
                end
                if not staminaDrain
                    and type(ups[1]) == "number" and ups[1] >= 0 and ups[1] <= 100
                    and type(ups[2]) == "boolean"
                    and type(ups[3]) == "number" and ups[3] > 1700000000 then
                    staminaDrain = v
                end
            end
        end
    end
end

local function findStaminaFuncs()
    staminaBar = nil
    staminaDrain = nil
    local ok, gc = pcall(getgc, false)
    if ok and gc then scanStaminaFrom(gc) end
    if not staminaBar or not staminaDrain then
        ok, gc = pcall(getgc, true)
        if ok and gc then scanStaminaFrom(gc) end
    end
    if not staminaBar or not staminaDrain then
        ok, gc = pcall(getgc)
        if ok and gc then scanStaminaFrom(gc) end
    end
end

--// Cached refs
local combatFunc = findCombatFunc()
