--//---------------------------------------------------------------
--// Function finders (single-pass GC scan)
--//---------------------------------------------------------------
local hitFuncs = {}
local slamHandler, slamRender
local staminaBar

local function scanAll()
    hitFuncs = {}
    slamHandler = nil
    slamRender = nil
    staminaBar = nil
    local ok, gc = pcall(getgc, false)
    if not ok or not gc then
        ok, gc = pcall(getgc)
        if not ok or not gc then return end
    end

    for _, v in ipairs(gc) do
        if type(v) ~= "function" then continue end

        local cOk, c = pcall(getconstants, v)
        if not cOk or not c then continue end

        local hasTick, hasPunch, hasTouched, hasCombat = false, false, false, false
        local hasAutoRotate, hasFireServer, hasDelay = false, false, false
        local hasSlam, hasFist, hasCycle = false, false, false
        local hasStamina = false

        for _, k in ipairs(c) do
            if k == "tick" then hasTick = true
            elseif k == "punch" then hasPunch = true
            elseif k == "Touched" then hasTouched = true
            elseif k == "combat" then hasCombat = true
            elseif k == "AutoRotate" then hasAutoRotate = true
            elseif k == "FireServer" then hasFireServer = true
            elseif k == "delay" then hasDelay = true
            elseif k == "Slam" then hasSlam = true
            elseif k == "fist" then hasFist = true
            elseif k == "cycle" then hasCycle = true
            elseif k == "Stamina" then hasStamina = true end
        end

        --// Hit/combat function: has tick+punch+Touched+combat
        if hasTick and hasPunch and hasTouched and hasCombat then
            table.insert(hitFuncs, v)
        end

        --// Slam handler: has AutoRotate+combat+FireServer+Slam, ups[17]=number
        if hasAutoRotate and hasCombat and hasFireServer and hasSlam and not slamHandler then
            local uOk, ups = pcall(getupvalues, v)
            if uOk and ups and type(ups[17]) == "number" then
                slamHandler = v
            end
        end

        --// Slam render: has cycle+Slam+FireServer, ups[8]=number
        if hasCycle and hasSlam and hasFireServer and not slamRender then
            local uOk, ups = pcall(getupvalues, v)
            if uOk and ups and type(ups[8]) == "number" then
                slamRender = v
            end
        end

        --// Stamina bar: must have "Stamina" constant + TweenService pattern
        if hasStamina and not staminaBar then
            local uOk, ups = pcall(getupvalues, v)
            if uOk and ups then
                if typeof(ups[1]) == "Instance" and ups[1].ClassName == "TweenService"
                    and type(ups[3]) == "number"
                    and type(ups[5]) == "boolean"
                    and type(ups[6]) == "number" and ups[6] < 1 then
                    staminaBar = v
                end
            end
        end

    end
end

scanAll()
local origReach = 6.5

--//---------------------------------------------------------------
--// Animation speed boost
--//---------------------------------------------------------------
local function boostAnims()
    local char = plr.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then return end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        local n = track.Name:lower()
        if n:find("punch") or n:find("kick") or n:find("slam") or n:find("head") or n:find("round") or n:find("grab") then
            if track.Speed ~= State.SwingMult then
                track:AdjustSpeed(State.SwingMult)
            end
        end
    end
end

local function resetAnims()
    pcall(function()
        local animator = plr.Character:FindFirstChildOfClass("Humanoid"):FindFirstChildOfClass("Animator")
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            track:AdjustSpeed(1)
        end
    end)
end

--//---------------------------------------------------------------
--// Hitbox expand (only Fist parts, stays invisible)
--//---------------------------------------------------------------
local origFistSize
local function setHitbox(on)
    local char = plr.Character
    if not char then return end
    if on then
        for _, name in ipairs({"RightHand", "LeftHand"}) do
            local p = char:FindFirstChild(name)
            if not p then continue end
            local fist = p:FindFirstChild("Fist")
            if not fist then continue end
            if not origFistSize then origFistSize = fist.Size end
            fist.Size = Vector3.new(State.HitboxSize, State.HitboxSize, State.HitboxSize)
            fist.Transparency = 1
            fist.CanCollide = false
        end
    else
        for _, name in ipairs({"RightHand", "LeftHand"}) do
            local p = char:FindFirstChild(name)
            if not p then continue end
            local fist = p:FindFirstChild("Fist")
            if fist and origFistSize then
                fist.Size = origFistSize
                fist.Transparency = 1
            end
        end
    end
end

--//---------------------------------------------------------------
--// Reach (setconstant on hit function)
--//---------------------------------------------------------------
local function setReach(val)
    for _, fn in ipairs(hitFuncs) do
        pcall(setconstant, fn, 1, val)
    end
end

--//---------------------------------------------------------------
--// ESP (parent to CoreGui so game can't remove them)
--//---------------------------------------------------------------
local espObjects = {}

local function clearESP()
    for _, h in pairs(espObjects) do
        pcall(function() h:Destroy() end)
    end
    table.clear(espObjects)
end

local function updateESP()
    if not State.ESP and not State.Highlight then
        clearESP()
        return
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if not espObjects[p] or not espObjects[p].Parent then
                if espObjects[p] then pcall(function() espObjects[p]:Destroy() end) end
                local h = Instance.new("Highlight")
                h.FillColor = Color3.fromRGB(255, 50, 50)
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
                h.FillTransparency = State.Highlight and 0.5 or 1
                h.OutlineTransparency = State.ESP and 0 or 1
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                h.Adornee = p.Character
                h.Parent = CoreGui
                espObjects[p] = h
            else
                local h = espObjects[p]
                h.Adornee = p.Character
                h.FillTransparency = State.Highlight and 0.5 or 1
                h.OutlineTransparency = State.ESP and 0 or 1
            end
        end
    end
    for p, h in pairs(espObjects) do
        if not p or not p.Parent or not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function() h:Destroy() end)
            espObjects[p] = nil
        end
    end
end

--//---------------------------------------------------------------
--// Kill aura
--//---------------------------------------------------------------
local lastAura = 0
local AURA_CD = 0.2

local function killAura()
    local now = tick()
    if now - lastAura < AURA_CD then return end
    lastAura = now
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local fists = {}
    for _, hand in ipairs({"RightHand", "LeftHand"}) do
        local h = char:FindFirstChild(hand)
        if h then
            local f = h:FindFirstChild("Fist")
            if f then table.insert(fists, f) end
        end
    end
    if #fists == 0 then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= plr and p.Character then
            local eHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local eHum = p.Character:FindFirstChild("Humanoid")
            if eHRP and eHum and eHum.Health > 0 then
                local dist = (hrp.Position - eHRP.Position).Magnitude
                if dist <= State.KillAuraRange then
                    for _, fist in ipairs(fists) do
                        pcall(firetouchinterest, fist, eHRP, 0)
                        task.defer(pcall, firetouchinterest, fist, eHRP, 1)
                    end
                end
            end
        end
    end
end

--//---------------------------------------------------------------
--// Main heartbeat loop
--//---------------------------------------------------------------
local lastRefresh = 0
local REFRESH_CD = 2

local function refreshRefs()
    local now = tick()
    if now - lastRefresh < REFRESH_CD then return end
    lastRefresh = now
    scanAll()
end

local function patchHitFuncs()
    if #hitFuncs == 0 then refreshRefs(); return false end
    local anyOk = false
    for _, fn in ipairs(hitFuncs) do
        local ok = pcall(function()
            setupvalue(fn, 18, 0)
            setupvalue(fn, 1, false)
            setupvalue(fn, 2, false)
            setupvalue(fn, 3, false)
            setupvalue(fn, 4, false)
            setupvalue(fn, 5, false)
            setupvalue(fn, 8, false)
        end)
        if ok then anyOk = true end
    end
    if not anyOk then hitFuncs = {}; refreshRefs() end
    return anyOk
end

cons.main = RunService.Heartbeat:Connect(function()
    --// Swing speed
    if State.SwingSpeed then
        boostAnims()
        patchHitFuncs()
    end

    --// Inf slam
    if State.InfSlam then
        if slamHandler then
            if not pcall(setupvalue, slamHandler, 17, 100) then
                slamHandler = nil; refreshRefs()
            end
        else
            refreshRefs()
        end
        if slamRender then
            if not pcall(setupvalue, slamRender, 8, 100) then
                slamRender = nil; refreshRefs()
            end
        end
        pcall(function()
            plr.PlayerGui.UI.Bars.Slam.Bar.Size = UDim2.new(1, 0, 1, 0)
        end)
    end

    --// Inf stamina
    if State.InfStamina then
        if staminaBar then
            local ok = pcall(setupvalue, staminaBar, 3, 100)
            if ok then pcall(setupvalue, staminaBar, 5, true) end
            if not ok then staminaBar = nil; refreshRefs() end
        else
            refreshRefs()
        end
    end

    --// Kill aura
    if State.KillAura then
        patchHitFuncs()
        killAura()
    end

    --// Walk speed
    if State.WalkSpeed then
        pcall(function() plr.Character.Humanoid.WalkSpeed = State.WalkSpeedVal end)
    end

    --// ESP
    updateESP()
end)

--//---------------------------------------------------------------
--// Respawn handler
--//---------------------------------------------------------------
cons.respawn = plr.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid")
    origFistSize = nil
    task.wait(1.5)
    for i = 1, 15 do
        scanAll()
        if #hitFuncs > 0 and slamHandler and staminaBar then break end
        task.wait(0.5)
    end
    lastRefresh = tick()
    if State.Reach then setReach(State.ReachVal) end
    if State.HitboxExpand then setHitbox(true) end
end)

--// Player removing for ESP cleanup
cons.playerRemoving = Players.PlayerRemoving:Connect(function(p)
    if espObjects[p] then
        pcall(function() espObjects[p]:Destroy() end)
        espObjects[p] = nil
    end
end)

