--// ─── HELPERS ───
local function isTeammate(player)
    local my = LocalPlayer:FindFirstChild("Party")
    local their = player:FindFirstChild("Party")
    if my and their then return my.Value == their.Value end
    return false
end

local function getLockedTarget()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local tagged = myChar:FindFirstChild("Tagged")
    if not tagged or not tagged:IsA("StringValue") or tagged.Value == "" then return nil end
    local tv = tagged.Value
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (p.Name == tv or p.DisplayName == tv) then return p end
    end
    return nil
end

local function getRealHP(player)
    local hpVal = player:FindFirstChild("Health")
    if hpVal and hpVal:IsA("IntValue") then return hpVal.Value end
    local hum = player.Character and player.Character:FindFirstChild("Humanoid")
    if hum then return math.floor(hum.Health) end
    return 0
end

--// ─── KILL AURA ───
local lastAtk = 0
local lastFistRefresh = 0
local COOLDOWN = 0.3
local fistActive = false

local function enterFist()
    pcall(function() CombatRemote:FireServer("fist") end)
    pcall(function() CombatRemote:FireServer("guarding") end)
end
local function exitFist()
    pcall(function() CombatRemote:FireServer("unblock") end)
    pcall(function() CombatRemote:FireServer("hands") end)
    pcall(function() CombatRemote:FireServer("unguard") end)
end
local function tryAttack(char)
    enterFist() -- Re-verify combat stance right before swinging
    pcall(function() CombatRemote:FireServer("head", char, false) end)
    task.defer(function()
        pcall(function() CombatRemote:FireServer("body", char, false) end)
    end)
end

-- Monitor getting hit to automatically refresh combat stance when stunned/damaged
local function monitorCharacter(char)
    if not char then return end
    task.spawn(function()
        local hum = char:WaitForChild("Humanoid", 5)
        if hum then
            local lastHP = hum.Health
            local conn
            conn = hum.HealthChanged:Connect(function(newHP)
                if newHP < lastHP then
                    -- Detected hit/damage taken!
                    if toggles["Kill Aura"] and newHP > 0 then
                        enterFist()
                        task.delay(0.2, function()
                            if toggles["Kill Aura"] and getRealHP(LocalPlayer) > 0 then enterFist() end
                        end)
                        task.delay(0.5, function()
                            if toggles["Kill Aura"] and getRealHP(LocalPlayer) > 0 then enterFist() end
                        end)
                    end
                end
                lastHP = newHP
            end)
            table.insert(_G.CAF2_Connections, conn)
        end
    end)
end

if LocalPlayer.Character then
    monitorCharacter(LocalPlayer.Character)
end

table.insert(_G.CAF2_Connections, RunService.Heartbeat:Connect(function()
    if not toggles["Kill Aura"] then
        if fistActive then fistActive = false; exitFist() end
        return
    end
    if not fistActive then fistActive = true; enterFist() end

    -- Do not attempt attacks if dead
    if getRealHP(LocalPlayer) <= 0 then return end

    local now = tick()
    -- Periodically refresh state in case server reset stance silently
    if now - lastFistRefresh > 0.75 then
        lastFistRefresh = now
        enterFist()
    end

    if now - lastAtk < COOLDOWN then return end
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local locked = getLockedTarget()
    if locked and not isTeammate(locked) then
        local char = locked.Character
        if char and char:FindFirstChild("HumanoidRootPart") and getRealHP(locked) > 0 then
            tryAttack(char); lastAtk = now; return
        end
    end

    local bestDist, bestChar = 15, nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and not isTeammate(p) then
            local char = p.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root and getRealHP(p) > 0 then
                    local d = (myRoot.Position - root.Position).Magnitude
                    if d < bestDist then bestDist = d; bestChar = char end
                end
            end
        end
    end
    if bestChar then tryAttack(bestChar); lastAtk = now end
end))

