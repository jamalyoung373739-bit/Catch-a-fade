--// ─── STAMINA + SLAM ───
local function patchAll()
    pcall(function()
        for _, fn in ipairs(getgc()) do
            if type(fn) == "function" and islclosure(fn) then
                local ok, name = pcall(debug.info, fn, "n")
                if ok then
                    if name == "takestamina" then hookfunction(fn, function() end)
                    elseif name == "regenstamina" then
                        debug.setupvalue(fn, 3, 9999)
                        debug.setupvalue(fn, 4, 9999)
                    end
                end
            end
        end
    end)
end
patchAll()

local lastPatch = 0
table.insert(_G.CAF2_Connections, RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastPatch < 0.5 then return end
    lastPatch = now

    if _G.CAF2_needPatch then _G.CAF2_needPatch = false; patchAll() end

    if toggles["Inf Stamina"] then
        pcall(function()
            for _, fn in ipairs(getgc()) do
                if type(fn) == "function" and islclosure(fn) then
                    local ok, name = pcall(debug.info, fn, "n")
                    if ok and name == "regenstamina" then
                        debug.setupvalue(fn, 3, 9999); break
                    end
                end
            end
        end)
    end

    if toggles["Inf Slam"] then
        pcall(function()
            for _, fn in ipairs(getgc()) do
                if type(fn) == "function" and islclosure(fn) then
                    local ok, name = pcall(debug.info, fn, "n")
                    if ok and name == "punch" then
                        debug.setupvalue(fn, 20, 100); break
                    end
                end
            end
        end)
    end
end))

--// ─── HEALTH ESP ───
local espFolder = Instance.new("Folder")
espFolder.Name = "CAF2_ESPFolder"
espFolder.Parent = CoreGui

local function makeBar(player)
    if espFolder:FindFirstChild(player.Name) then return end
    local char = player.Character
    if not char or not char:FindFirstChild("Head") then return end

    local bill = Instance.new("BillboardGui")
    bill.Name = player.Name
    bill.Adornee = char.Head
    bill.Size = UDim2.new(0, 60, 0, 12)
    bill.StudsOffset = Vector3.new(0, 2.5, 0)
    bill.AlwaysOnTop = true
    bill.MaxDistance = 200
    bill.Parent = espFolder

    local nl = Instance.new("TextLabel")
    nl.Size = UDim2.new(1, 0, 0, 10)
    nl.Position = UDim2.new(0, 0, -1.2, 0)
    nl.BackgroundTransparency = 1
    nl.Text = player.DisplayName
    nl.TextColor3 = Color3.fromRGB(255, 255, 255)
    nl.TextStrokeTransparency = 0.5
    nl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nl.Font = Enum.Font.SourceSansBold
    nl.TextSize = 13
    nl.Parent = bill

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    bg.BorderSizePixel = 0
    bg.Parent = bill
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 3)

    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.Size = UDim2.new(1, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
    fill.BorderSizePixel = 0
    fill.Parent = bg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local hp = Instance.new("TextLabel")
    hp.Name = "HP"
    hp.Size = UDim2.new(1, 0, 1, 0)
    hp.BackgroundTransparency = 1
    hp.TextColor3 = Color3.fromRGB(255, 255, 255)
    hp.TextStrokeTransparency = 0.5
    hp.Font = Enum.Font.SourceSansBold
    hp.TextSize = 10
    hp.ZIndex = 2
    hp.Parent = bg
end

table.insert(_G.CAF2_Connections, RunService.Heartbeat:Connect(function()
    if not toggles["Health ESP"] then
        if #espFolder:GetChildren() > 0 then espFolder:ClearAllChildren() end
        return
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local char = p.Character
            local bill = espFolder:FindFirstChild(p.Name)
            if char and char:FindFirstChild("Head") then
                if not bill then makeBar(p) end
                bill = espFolder:FindFirstChild(p.Name)
                if bill then
                    bill.Adornee = char:FindFirstChild("Head")
                    local hp = getRealHP(p)
                    local pct = math.clamp(hp / 100, 0, 1)
                    local bg = bill:FindFirstChildWhichIsA("Frame")
                    if bg then
                        local fill = bg:FindFirstChild("Fill")
                        if fill then
                            fill.Size = UDim2.new(pct, 0, 1, 0)
                            fill.BackgroundColor3 = Color3.fromRGB(255 * (1 - pct), 255 * pct, 50 * pct)
                        end
                        local hpL = bg:FindFirstChild("HP")
                        if hpL then hpL.Text = hp .. "/100" end
                    end
                end
            else
                if bill then bill:Destroy() end
            end
        end
    end
end))

table.insert(_G.CAF2_Connections, Players.PlayerRemoving:Connect(function(p)
    local b = espFolder:FindFirstChild(p.Name)
    if b then b:Destroy() end
end))
